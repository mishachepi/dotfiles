# If not running interactively, don't do anything
[[ $- != *i* ]] && return

export ZSH="$HOME/.oh-my-zsh"
ZSH_CUSTOM="$HOME/dotfiles/zsh" # See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="mch"
# plugins=(git)
ZSH_COMPDUMP=~/.zcompdump
source $ZSH/oh-my-zsh.sh

# General
export EDITOR='nvim'
export VISUAL='nvim'
# VAULT_HOME → ~/.local_env.zsh

# Additional PATH
if [[ -d "$HOME/dotfiles/scripts" ]]; then
  path=("$HOME/dotfiles/scripts" $path)
fi
# bun global packages (qmd, etc.)
if [[ -d "$HOME/.bun/bin" ]]; then
  path=("$HOME/.bun/bin" $path)
fi
# Go binaries
if [[ -d "$HOME/go/bin" ]]; then
  path=("$HOME/go/bin" $path)
fi

# set vi mode
set -o vi

# Aliases
source $HOME/dotfiles/aliases.sh

# nnn file manager (plugins via ;key, preview-tui needs tmux)
export NNN_FIFO='/tmp/nnn.fifo'
export NNN_PLUG='p:preview-tui;o:fzopen;d:dragdrop'
export NNN_BMS='p:~/projects;d:~/dotfiles;h:~'
export NNN_FCOLORS='c1e2272e006033f7c6d6abc4'
export NNN_BATTHEME='ansi'
export NNN_PAGER='less -R'

# devtools
export KUBECONFIG=$HOME/.kube/config:$(find ~/.kube/configs -type f | tr '\n' ':' | sed 's/:$//')

awslogin() {
  local profile
  profile=$(aws configure list-profiles | fzf) || return
  export AWS_PROFILE="$profile"
  echo "AWS_PROFILE=$AWS_PROFILE"
  aws sso login
  aws sts get-caller-identity
}

# Completions (fpath must be before compinit, oh-my-zsh already calls compinit)
fpath+=~/.zfunc

[ -f "$HOME/.local_env.zsh" ] && source "$HOME/.local_env.zsh"

fpath+=~/.zfunc
fpath=(/Users/mikhailchepkin/.docker/completions $fpath)
autoload -Uz compinit
compinit

zstyle ':completion:*' menu select


# Added by Antigravity CLI installer
export PATH="/Users/m_chepkin/.local/bin:$PATH"
