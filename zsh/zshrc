# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Completions (fpath must be set before compinit; oh-my-zsh calls compinit)
fpath+=~/.zfunc
[[ -d "$HOME/.docker/completions" ]] && fpath+=("$HOME/.docker/completions")

export ZSH="$HOME/.oh-my-zsh"
ZSH_CUSTOM="$HOME/dotfiles/zsh" # See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="mch"
# plugins=(git)
ZSH_COMPDUMP=~/.zcompdump
source $ZSH/oh-my-zsh.sh

# General
export EDITOR='nvim'
export VISUAL='nvim'
# VAULT_HOME → ~/.local_env.zsh

# Additional PATH
if [[ -d "$HOME/dotfiles/scripts" ]]; then
  path=("$HOME/dotfiles/scripts" $path)
fi
# bun global packages (qmd, etc.)
if [[ -d "$HOME/.bun/bin" ]]; then
  path=("$HOME/.bun/bin" $path)
fi
# Go binaries
if [[ -d "$HOME/go/bin" ]]; then
  path=("$HOME/go/bin" $path)
fi
# Local binaries (uv tools, standalone installers)
if [[ -d "$HOME/.local/bin" ]]; then
  path=("$HOME/.local/bin" $path)
fi

# set vi mode
set -o vi

# Aliases
source $HOME/dotfiles/aliases.sh

# devtools
mkdir -p ~/.kube/configs
export KUBECONFIG=$HOME/.kube/config:$(find ~/.kube/configs -type f | tr '\n' ':' | sed 's/:$//')

awslogin() {
  local profile
  profile=$(aws configure list-profiles | fzf) || return
  export AWS_PROFILE="$profile"
  echo "AWS_PROFILE=$AWS_PROFILE"
  aws sso login
  aws sts get-caller-identity
}

[ -f "$HOME/.local_env.zsh" ] && source "$HOME/.local_env.zsh"

zstyle ':completion:*' menu select

fpath+=~/.zfunc; autoload -Uz compinit; compinit
